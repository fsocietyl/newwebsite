        { "source": "/store/store-sample-2/", "destination": "/store/store-sample-2/index.html" }
      ],
      "headers": [
        {
          "source": "/store/**",
          "headers": [
            { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
          ]
        }
      ]
    },
