      "public": "out",
      "cleanUrls": true,
      "trailingSlash": true,
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
      "rewrites": [
        { "source": "/store", "destination": "/store/index.html" },
        { "source": "/store/", "destination": "/store/index.html" },
        { "source": "/store/cart", "destination": "/store/cart/index.html" },
        { "source": "/store/cart/", "destination": "/store/cart/index.html" },
        { "source": "/store/store-sample", "destination": "/store/store-sample/index.html" },
        { "source": "/store/store-sample/", "destination": "/store/store-sample/index.html" },
